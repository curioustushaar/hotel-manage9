# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# MongoDB Atlas Connection URI
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?appName=myapp
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.mfempxz.mongodb.net/hotel-management?appName=Cluster0

# ============================================================
# SERVER CONFIGURATION
# ============================================================
# Server Port (default: 5000)
PORT=5000

# Node Environment (development, production, testing)
NODE_ENV=development

# ============================================================
# FRONTEND CONFIGURATION (CORS)
# ============================================================
# Frontend URL for CORS - Update with your actual frontend URL
# Development: http://localhost:5173 or http://localhost:3000
# Production: https://your-frontend-domain.vercel.app
FRONTEND_URL=http://localhost:5173

# ============================================================
# SECURITY (Optional)
# ============================================================
# JWT Secret for authentication (generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# CORS allowed origins (comma-separated if multiple)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
