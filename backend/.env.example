# Backend Environment Variables

# MongoDB Connection
# Local: mongodb://localhost:27017/bareena-atithi
# Production: mongodb+srv://username:password@cluster.mongodb.net/bareena-atithi
MONGODB_URI=mongodb://localhost:27017/bareena-atithi

# Server Port
PORT=5000

# Frontend URL for CORS (Production - Update with your Vercel frontend URL)
FRONTEND_URL=https://your-app.vercel.app

# Node Environment
NODE_ENV=development
